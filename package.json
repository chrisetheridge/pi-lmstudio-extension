{
  "name": "pi-extension-lmstudio",
  "version": "0.1.0",
  "description": "Pi extension that auto-registers LM Studio models as local models.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "lmstudio"
  ],
  "files": [
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.70.0",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "consola": "^3.4.2"
  }
}
